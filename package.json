	"devDependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"@types/markdown-to-jsx": "^7.0.1",
		"@types/node": "^20.19.37",
		"@types/react": "19.1.8",
		"@types/react-dom": "19.1.6",
		"cross-env": "^10.1.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^8.57.1",
		"eslint-config-next": "16.1.6",
		"prettier": "^3.8.1",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@sentry/cli",
			"bufferutil",
			"core-js",
			"es5-ext",
			"esbuild",
			"protobufjs",
			"sharp",
			"unrs-resolver",
			"utf-8-validate"
		]
	}
