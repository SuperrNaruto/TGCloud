{
	"name": "tg-cloud",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev:turbo": "cross-env NODE_OPTIONS='--inspect' dotenv -e .env.development -- next dev --turbo -p 3000",
		"dev": "cross-env NODE_OPTIONS='--inspect' dotenv -e .env.development -- next dev ",
		"build:local": "dotenv -e .env.development -- next build",
		"build": "cross-env NODE_ENV=production npx drizzle-kit migrate && next build",
		"start": "next start",
		"lint": "next lint",
		"db:generate": "dotenv -e .env.development -- drizzle-kit generate",
		"db:migrate": "dotenv -e .env.development  -- drizzle-kit migrate",
		"db:push": "dotenv -e .env.development -- drizzle-kit push",
		"migrate": "pnpm db:generate && pnpm db:migrate",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "tsc --project tsconfig.json"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.5",
		"@better-auth/infra": "^0.1.12",
		"@bprogress/next": "^3.2.12",
		"@next/env": "16.1.6",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@react-email/components": "^0.0.22",
		"@sentry/nextjs": "^8.55.0",
		"@t3-oss/env-nextjs": "^0.10.1",
		"@tanstack/react-query": "^5.91.2",
		"@types/pg": "^8.18.0",
		"@uidotdev/usehooks": "^2.4.1",
		"async-mutex": "^0.5.0",
		"better-auth": "^1.5.5",
		"big-integer": "^1.6.52",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"dexie": "^4.3.0",
		"dotenv-cli": "^7.4.4",
		"drizzle-orm": "^0.45.1",
		"fluid-player": "^3.58.0",
		"lucide-react": "^0.402.0",
		"markdown-to-jsx": "^9.7.11",
		"mp4box": "^0.5.4",
		"next": "16.2.0",
		"next-nprogress-bar": "^2.4.7",
		"next-themes": "^0.3.0",
		"pg": "^8.20.0",
		"posthog-js": "^1.363.0",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-dropzone": "^15.0.0",
		"resend": "^3.5.0",
